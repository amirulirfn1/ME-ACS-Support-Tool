<Window x:Class="MEACSSupportTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ME ACS Support Tool"
        Icon="Assets/me-acs-support-tool.ico"
        Width="1000"
        Height="800"
        MinWidth="860"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40"
                            Background="{DynamicResource BrandAccentSoft}"
                            BorderBrush="{DynamicResource BrandAccentLine}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Margin="0,0,12,0">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrandAccent}"
                                   Text="ME" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ME ACS Support Tool"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding AppSubtitleText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}" />
                        <WrapPanel Margin="0,4,0,0">
                            <Border Style="{StaticResource StatusBadge}">
                                <TextBlock Style="{StaticResource StatusBadgeText}" Text="{Binding AppBuildText}" />
                            </Border>
                            <Border Style="{StaticResource StatusBadge}">
                                <TextBlock Style="{StaticResource StatusBadgeText}" Text="{Binding UpdateSummaryText}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Margin="0,0,8,0"
                            Click="RefreshStatusButton_Click"
                            IsEnabled="{Binding IsNotRefreshing}"
                            Style="{StaticResource BtnSecondary}"
                            Content="Refresh Status" />
                    <Button Margin="0,0,8,0"
                            Click="CheckForToolkitUpdatesButton_Click"
                            IsEnabled="{Binding IsNotRefreshing}"
                            Style="{StaticResource BtnSecondary}"
                            Content="Check Updates" />
                    <Button Click="OpenLogsFolderButton_Click"
                            Style="{StaticResource BtnSecondary}"
                            Padding="10,8"
                            FontSize="12"
                            Content="Logs" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Admin warning — only shown when not running as administrator -->
        <Border Grid.Row="1"
                Padding="14,10"
                Margin="0,0,0,8"
                Background="{DynamicResource WarningSoft}"
                BorderBrush="{DynamicResource Warning}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding AdminWarningVisibility}">
            <TextBlock Text="Not running as Administrator — RabbitMQ Repair requires admin rights to work."
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Warning}" />
        </Border>

        <!-- Status strip -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <WrapPanel>
                    <Border Style="{StaticResource MetaBadge}">
                        <StackPanel>
                            <TextBlock Text="Machine" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="{Binding MachineName}" Style="{StaticResource StatusBadgeText}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetaBadge}">
                        <StackPanel>
                            <TextBlock Text="User" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="{Binding CurrentUser}" Style="{StaticResource StatusBadgeText}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusBadge}"
                            Background="{Binding InternetBadgeBg}"
                            BorderBrush="{Binding InternetBadgeBorder}">
                        <StackPanel>
                            <TextBlock Text="Internet" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="{Binding InternetStatus}" Style="{StaticResource StatusBadgeText}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusBadge}"
                            Background="{Binding RabbitMqBadgeBg}"
                            BorderBrush="{Binding RabbitMqBadgeBorder}">
                        <StackPanel>
                            <TextBlock Text="RabbitMQ" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="{Binding RabbitMqStatus}" Style="{StaticResource StatusBadgeText}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusBadge}"
                            Background="{Binding SqlBadgeBg}"
                            BorderBrush="{Binding SqlBadgeBorder}">
                        <StackPanel>
                            <TextBlock Text="SQL" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="{Binding SqlStatus}" Style="{StaticResource StatusBadgeText}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusBadge}"
                            Background="{Binding DatabaseBadgeBg}"
                            BorderBrush="{Binding DatabaseBadgeBorder}">
                        <StackPanel>
                            <TextBlock Text="Database" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="{Binding DatabaseStatus}" Style="{StaticResource StatusBadgeText}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusBadge}"
                            Background="{Binding SsmsBadgeBg}"
                            BorderBrush="{Binding SsmsBadgeBorder}">
                        <StackPanel>
                            <TextBlock Text="SSMS" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="{Binding SsmsStatus}" Style="{StaticResource StatusBadgeText}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock HorizontalAlignment="Right" Text="Last refresh" Style="{StaticResource EyebrowText}" />
                    <TextBlock HorizontalAlignment="Right"
                               Margin="0,3,0,0"
                               Text="{Binding LastRefreshText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: Quick Repairs + SQL Patcher -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Quick Repairs -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20" Margin="0,0,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Quick Repairs" Style="{StaticResource SectionHeaderText}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="Run common fixes directly on this machine."
                               Style="{StaticResource FieldLabelText}" />

                    <!-- RabbitMQ Repair -->
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="RabbitMQ Repair"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Reinstall RabbitMQ and Erlang after a PC rename or broken service."
                                       Style="{StaticResource FieldLabelText}" />
                            <WrapPanel Margin="0,8,0,0">
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="Admin required" />
                                </Border>
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="Internet required" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Width="72"
                                Click="RunRabbitMqRepairButton_Click"
                                IsEnabled="{Binding IsNotBusy}"
                                Style="{StaticResource BtnPrimary}"
                                Content="Run" />
                    </Grid>

                    <Rectangle Margin="0,18,0,0" Height="1" Fill="{DynamicResource BorderColor}" />

                    <!-- Solve Client Lag -->
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Solve Client Lag"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Apply the bundled SQL optimisation to the local magetegra database."
                                       Style="{StaticResource FieldLabelText}" />
                            <WrapPanel Margin="0,8,0,0">
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="Local SQL" />
                                </Border>
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="Idempotent" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Width="72"
                                Click="RunSolveClientLagButton_Click"
                                IsEnabled="{Binding IsNotBusy}"
                                Style="{StaticResource BtnPrimary}"
                                Content="Run" />
                    </Grid>

                    <Rectangle Margin="0,18,0,0" Height="1" Fill="{DynamicResource BorderColor}" />

                    <!-- Install SSMS -->
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Install SSMS"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Download SQL Server Management Studio and open the installer."
                                       Style="{StaticResource FieldLabelText}" />
                            <WrapPanel Margin="0,8,0,0">
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="Internet required" />
                                </Border>
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="One-time setup" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Width="72"
                                Click="RunInstallSsmsButton_Click"
                                IsEnabled="{Binding IsNotBusy}"
                                Style="{StaticResource BtnPrimary}"
                                Content="Run" />
                    </Grid>

                    <Rectangle Margin="0,18,0,0" Height="1" Fill="{DynamicResource BorderColor}" />

                    <!-- Create Local User -->
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Create Local User"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Create or repair the local magetegra support account and keep the password from expiring."
                                       Style="{StaticResource FieldLabelText}" />
                            <WrapPanel Margin="0,8,0,0">
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="Admin required" />
                                </Border>
                                <Border Style="{StaticResource StatusBadge}">
                                    <TextBlock Style="{StaticResource StatusBadgeText}" Text="Local account" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Width="72"
                                Click="RunCreateSupportUserButton_Click"
                                IsEnabled="{Binding IsNotBusy}"
                                Style="{StaticResource BtnPrimary}"
                                Content="Run" />
                    </Grid>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <ScrollViewer Grid.Column="1" Margin="8,0,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- SQL Patcher — primary focus for support staff -->
                    <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="SQL Patcher" Style="{StaticResource SectionHeaderText}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Patch a Magetegra database backup to a target version."
                                       Style="{StaticResource FieldLabelText}" />

                            <Border Style="{StaticResource StatusBadge}" HorizontalAlignment="Left" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource StatusBadgeText}" Text="{Binding SqlPatcherStatus}" />
                            </Border>

                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding SqlPatcherBuildText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding SqlPatcherDetails}"
                                       Style="{StaticResource FieldLabelText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding SqlPatcherLocation}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap" />

                            <Button Margin="0,18,0,8"
                                    HorizontalAlignment="Stretch"
                                    Click="LaunchSqlPatcherButton_Click"
                                    IsEnabled="{Binding CanLaunchSqlPatcher}"
                                    Style="{StaticResource BtnPrimary}"
                                    Content="Open SQL Patcher" />
                            <Button HorizontalAlignment="Stretch"
                                    Click="OpenSqlPatcherWorkspaceButton_Click"
                                    IsEnabled="{Binding CanOpenSqlPatcherWorkspace}"
                                    Style="{StaticResource BtnSecondary}"
                                    Content="Open Extension Folder" />
                        </StackPanel>
                    </Border>

                    <!-- Update available banner — only shows when an update is ready -->
                    <Border Margin="0,0,0,8"
                            Padding="14,12"
                            Background="{DynamicResource SuccessSoft}"
                            BorderBrush="{DynamicResource Success}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding ApplyUpdateVisibility}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="Update available"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Success}" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding UpdateStatusText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="ApplyToolkitUpdateButton_Click"
                                    IsEnabled="{Binding CanApplyToolkitUpdate}"
                                    Style="{StaticResource BtnPrimary}"
                                    Content="Apply Update" />
                        </Grid>
                    </Border>

                    <!-- Toolkit Updates — maintainer section, collapsed by default -->
                    <Expander IsExpanded="False" Margin="0,0,0,4">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Toolkit Updates"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center" />
                                <Border Background="{DynamicResource SurfaceSubtle}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UpdateSummaryText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}" />
                                </Border>
                            </StackPanel>
                        </Expander.Header>
                        <Border Style="{StaticResource Card}" Padding="16" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="Update source" Style="{StaticResource EyebrowText}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding UpdateFeedPathText}"
                                           Style="{StaticResource FieldLabelText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0" Text="Last check" Style="{StaticResource EyebrowText}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding LastUpdateCheckText}"
                                           Style="{StaticResource FieldLabelText}"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Margin="0,0,8,8"
                                            Click="SetUpdateFeedUrlButton_Click"
                                            Style="{StaticResource BtnSecondary}"
                                            Content="Set Feed URL" />
                                    <Button Margin="0,0,8,8"
                                            Click="ConfigureUpdateFeedButton_Click"
                                            Style="{StaticResource BtnSecondary}"
                                            Content="Set Feed Folder" />
                                    <Button Margin="0,0,0,8"
                                            Click="ClearUpdateFeedButton_Click"
                                            Style="{StaticResource BtnSecondary}"
                                            Content="Clear Feed" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Bottom: Status banner + activity log | Recent runs -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Status banner + live log -->
            <Border Grid.Column="0" Style="{StaticResource NextActionBanner}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{Binding StatusBanner}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,10,0,0"
                                Orientation="Vertical"
                                Visibility="{Binding BusyIndicatorVisibility}">
                        <TextBlock Text="{Binding BusyIndicatorText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}" />
                        <ProgressBar Margin="0,6,0,0"
                                     Height="6"
                                     IsIndeterminate="True" />
                    </StackPanel>
                    <TextBox Margin="0,10,0,0"
                             Height="100"
                             Style="{StaticResource ReadOnlyConsoleTextBox}"
                             Text="{Binding LiveLogText, Mode=OneWay}"
                             Visibility="{Binding ActivityConsoleVisibility}" />
                    <Button Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Click="OpenCurrentLogButton_Click"
                            IsEnabled="{Binding CanOpenCurrentLog}"
                            Style="{StaticResource BtnSecondary}"
                            Content="Open Log File"
                            Visibility="{Binding ActivityConsoleVisibility}" />
                </StackPanel>
            </Border>

            <!-- Recent runs -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Recent runs" Style="{StaticResource SectionHeaderText}" />
                    <DataGrid Margin="0,10,0,0"
                              MaxHeight="160"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding HistoryItems}"
                              ToolTip="Double-click a row to open its log file"
                              MouseDoubleClick="HistoryGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding StartedAt}" Header="Started" Width="140" />
                            <DataGridTextColumn Binding="{Binding ActionName}" Header="Action" Width="145" />
                            <DataGridTextColumn Binding="{Binding Outcome}" Header="Outcome" Width="90" />
                            <DataGridTextColumn Binding="{Binding Summary}" Header="Summary" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
