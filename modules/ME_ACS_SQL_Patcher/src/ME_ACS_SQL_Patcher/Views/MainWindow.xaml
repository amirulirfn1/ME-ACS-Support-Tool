<Window x:Class="MagDbPatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MagDbPatcher.Models"
        xmlns:vm="clr-namespace:MagDbPatcher.ViewModels"
        Title="ME_ACS SQL Patcher"
        Icon="/Assets/me-acs-patcher.ico"
        Height="720" Width="960"
        MinHeight="580" MinWidth="860"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="40"
                            Height="40"
                            Background="{StaticResource BrandAccentSoft}"
                            BorderBrush="{StaticResource BrandAccentLine}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="7"
                            Margin="0,0,12,0">
                        <Image Source="/Assets/me-acs-patcher.png"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"/>
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ME ACS SQL Patcher"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="MagEtegra database backup patcher"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <WrapPanel Margin="0,4,0,0" ItemHeight="16">
                            <TextBlock x:Name="txtBuildVersion"
                                       Text="{Binding AppBuildText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,10,0"/>
                            <TextBlock x:Name="txtVersion"
                                       Text="{Binding PatchVersionText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,10,0"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            HorizontalAlignment="Right">
                    <Button x:Name="btnImportPatchPack"
                            Content="Import Patches"
                            AutomationProperties.Name="Import patch pack zip"
                            Style="{StaticResource BtnSecondary}"
                            MinWidth="120"
                            Padding="12,8"
                            Margin="0,0,6,0"
                            Click="BtnImportPatchPack_Click"/>

                    <Button x:Name="btnToggleTheme"
                            x:FieldModifier="private"
                            Content="Dark Mode"
                            AutomationProperties.Name="Toggle color theme"
                            Style="{StaticResource BtnSecondary}"
                            MinWidth="86"
                            Padding="10,8"
                            Margin="0,0,6,0"
                            Click="BtnToggleTheme_Click"/>

                    <Button x:Name="btnAdminTools"
                            Content="Admin"
                            AutomationProperties.Name="Open admin tools"
                            Style="{StaticResource BtnSecondary}"
                            MinWidth="66"
                            Padding="10,8"
                            Margin="0,0,0,0"
                            Click="BtnAdminTools_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource NextActionBanner}" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="▸"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource BrandAccent}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock x:Name="txtNextAction"
                       Text="{Binding NextActionText}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 2: Step Progress Indicator -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="16,9" Margin="0,0,0,8">
            <Grid>
                <!-- Background connecting line aligned to circle centers (14 = 28/2) -->
                <Rectangle Height="2" VerticalAlignment="Top" Margin="0,14,0,0"
                           Fill="{DynamicResource BorderColor}"/>
                <UniformGrid Rows="1" Columns="4">
                    <StackPanel HorizontalAlignment="Center">
                        <Border x:Name="bdStep1Circle" Width="28" Height="28" CornerRadius="14"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource BgSecondary}"
                                BorderBrush="{DynamicResource BorderStrong}" BorderThickness="2">
                            <TextBlock x:Name="txtStep1Circle" Text="1" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtStep1Label" Text="Select" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <Border x:Name="bdStep2Circle" Width="28" Height="28" CornerRadius="14"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource BgSecondary}"
                                BorderBrush="{DynamicResource BorderStrong}" BorderThickness="2">
                            <TextBlock x:Name="txtStep2Circle" Text="2" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtStep2Label" Text="Versions" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <Border x:Name="bdStep3Circle" Width="28" Height="28" CornerRadius="14"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource BgSecondary}"
                                BorderBrush="{DynamicResource BorderStrong}" BorderThickness="2">
                            <TextBlock x:Name="txtStep3Circle" Text="3" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtStep3Label" Text="Connect" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <Border x:Name="bdStep4Circle" Width="28" Height="28" CornerRadius="14"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource BgSecondary}"
                                BorderBrush="{DynamicResource BorderStrong}" BorderThickness="2">
                            <TextBlock x:Name="txtStep4Circle" Text="4" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtStep4Label" Text="Run" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="0,0,10,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,6" Padding="12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Step 1: Select Backup" Style="{StaticResource SectionHeaderText}"/>
                            <Border x:Name="bdStep1Status" Grid.Column="1" Style="{StaticResource StepStatusChip}">
                                <TextBlock x:Name="txtStep1Status" Text="Pending" Style="{StaticResource StepStatusChipText}"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Pick the source .bak file." Style="{StaticResource FieldLabelText}" Margin="0,6,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <ComboBox x:Name="cmbSourcePath"
                                          TabIndex="1"
                                          IsEditable="True"
                                          AutomationProperties.Name="Source backup path"
                                          Style="{StaticResource DarkEditableComboBox}"
                                          FontSize="14"
                                          SelectionChanged="CmbSourcePath_SelectionChanged"/>
                                <TextBlock x:Name="txtSourcePlaceholder"
                                           Text="Click Browse or type a .bak path..."
                                           FontSize="13"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="14,0,34,0"
                                           IsHitTestVisible="False"
                                           Visibility="Visible"/>
                            </Grid>

                            <Button x:Name="btnBrowse"
                                    Grid.Column="1"
                                    TabIndex="2"
                                    Content="Browse"
                                    AutomationProperties.Name="Browse for source backup"
                                    Style="{StaticResource BtnSecondary}"
                                    Margin="10,0,0,0"
                                    MinWidth="84"
                                    Click="BtnBrowse_Click"/>
                        </Grid>
                        <TextBlock x:Name="txtSourceFileHint" Margin="0,6,0,0" FontSize="12"
                                   Text="{Binding SourceFileHintText}"
                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,6" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Step 2: Choose Versions" Style="{StaticResource SectionHeaderText}"/>
                            <Border x:Name="bdStep2Status" Grid.Column="1" Style="{StaticResource StepStatusChip}">
                                <TextBlock x:Name="txtStep2Status" Text="Pending" Style="{StaticResource StepStatusChipText}"/>
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1" Text="Select the backup's current version and where to upgrade to." Style="{StaticResource FieldLabelText}" Margin="0,6,0,10"/>

                        <StackPanel Grid.Row="2">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="From" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="cmbFromVersion"
                                          Grid.Column="1"
                                          TabIndex="3"
                                          AutomationProperties.Name="From version"
                                          Style="{StaticResource DarkComboBox}"
                                          FontSize="14"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectionChanged="CmbFromVersion_SelectionChanged"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="To" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="cmbToVersion"
                                          Grid.Column="1"
                                          TabIndex="4"
                                          AutomationProperties.Name="To version"
                                          Style="{StaticResource DarkComboBox}"
                                          FontSize="14"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectionChanged="CmbToVersion_SelectionChanged"/>

                                <Button x:Name="btnPatchToLatest"
                                        Grid.Column="2"
                                        TabIndex="5"
                                        Margin="10,0,0,0"
                                        Content="Latest"
                                        AutomationProperties.Name="Select latest target version"
                                        Style="{StaticResource BtnSecondary}"
                                        MinWidth="84"
                                        Click="BtnPatchToLatest_Click"/>
                            </Grid>
                        </StackPanel>

                        <Border x:Name="bdUpgradePath" Grid.Row="3"
                                Background="{DynamicResource BgTertiary}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1" CornerRadius="6" Padding="10,7"
                                Margin="0,8,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="txtUpgradePath"
                                       Text="{Binding UpgradePathText}"
                                       FontSize="12" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}" VerticalAlignment="Top" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Step 3: Check Connection" Style="{StaticResource SectionHeaderText}"/>
                            <Border x:Name="bdStep3Status" Grid.Column="1" Style="{StaticResource StepStatusChip}">
                                <TextBlock x:Name="txtStep3Status" Text="Pending" Style="{StaticResource StepStatusChipText}"/>
                            </Border>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="Enter your SQL Server instance and test the connection." Style="{StaticResource FieldLabelText}" Margin="0,6,0,10"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cmbSqlServer"
                                      Grid.Column="0"
                                      TabIndex="20"
                                      IsEditable="True"
                                      AutomationProperties.Name="SQL server instance"
                                      Style="{StaticResource DarkEditableComboBox}"
                                      FontSize="13"/>
                            <Button x:Name="btnTestSql"
                                    Grid.Column="1"
                                    TabIndex="25"
                                    Content="Test Connection"
                                    AutomationProperties.Name="Test SQL connection"
                                    Style="{StaticResource BtnSecondary}"
                                    Margin="10,0,0,0"
                                    MinWidth="120"
                                    Click="BtnTestSql_Click"/>
                        </Grid>

                        <StackPanel Grid.Row="3" Margin="0,6,0,0">
                            <TextBlock x:Name="txtSqlTestResult"
                                       Text="{Binding SqlTestResultText}"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Local only. Use .\INSTANCE or (localdb)\MSSQLLocalDB. Default is .\MAGSQL."
                                       FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Expander x:Name="expConnectionSettings" Grid.Row="4" IsExpanded="False" Margin="0,12,0,0">
                            <Expander.Header>
                                <TextBlock Text="Advanced Settings / Admin" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                            </Expander.Header>
                            <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <StackPanel>
                                    <TextBlock Text="Authentication" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton x:Name="rbAuthWindows" TabIndex="21" Content="Windows" IsChecked="True" Margin="0,0,16,0" Checked="AuthMode_Checked"/>
                                        <RadioButton x:Name="rbAuthSql" TabIndex="22" Content="SQL Login" Checked="AuthMode_Checked"/>
                                    </StackPanel>
                                    <StackPanel x:Name="pnlSqlLogin" Margin="0,0,0,8" Visibility="Collapsed">
                                        <TextBlock Text="Username" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="txtSqlUsername" TabIndex="23" FontSize="13" TextChanged="AdvancedRunSettingTextChanged"/>
                                        <TextBlock Text="Password" Style="{StaticResource FieldLabelText}" Margin="0,10,0,6"/>
                                        <PasswordBox x:Name="pwdSqlPassword" TabIndex="24" FontSize="13" PasswordChanged="AdvancedRunSettingPasswordChanged"/>
                                    </StackPanel>

                                    <TextBlock Text="Run Behavior" Style="{StaticResource FieldLabelText}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                                            <TextBlock Text="Temp folder" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="txtTempFolder" FontSize="12" TextChanged="AdvancedRunSettingTextChanged"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical">
                                            <Button x:Name="btnBrowseTempFolder" Content="Browse" Style="{StaticResource BtnSecondary}" Margin="0,22,0,8" Click="BtnBrowseTempFolder_Click"/>
                                            <Button x:Name="btnResetTempFolder" Content="Default" Style="{StaticResource BtnSecondary}" Click="BtnResetTempFolder_Click"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="SQL error handling" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="cmbErrorMode" FontSize="12" SelectedValuePath="Tag" SelectionChanged="AdvancedRunSettingSelectionChanged">
                                                <ComboBoxItem Tag="{x:Static models:PatchErrorMode.WarnAndContinue}" Content="Warn and continue"/>
                                                <ComboBoxItem Tag="{x:Static models:PatchErrorMode.FailFast}" Content="Fail fast"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="Warning threshold" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="txtWarningThreshold" FontSize="12" TextChanged="AdvancedRunSettingTextChanged"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Patches Folder" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtPatchesFolder" IsReadOnly="True" FontSize="12" Margin="0,0,0,8"/>
                                    <TextBlock Text="The managed patch library lives in LocalAppData so app reinstalls and manual app upgrades do not wipe imported SQL content. Use a custom folder only for advanced troubleshooting." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button x:Name="btnChangePatchesFolder" Content="Change" Style="{StaticResource BtnSecondary}" Margin="0,0,8,8" MinWidth="74" Click="BtnChangePatchesFolder_Click"/>
                                        <Button x:Name="btnOpenPatchesFolder" Content="Open" Style="{StaticResource BtnSecondary}" Margin="0,0,8,8" MinWidth="64" Click="BtnOpenPatchesFolder_Click"/>
                                        <Button x:Name="btnResetPatchesFolder" Content="Reset to Managed Library" Style="{StaticResource BtnSecondary}" Margin="0,0,8,8" MinWidth="174" Click="BtnResetPatchesFolder_Click"/>
                                    </WrapPanel>
                                    <TextBlock x:Name="txtLastImportedPack" Text="" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Expander>
                    </Grid>
                </Border>
            </Grid>
            </ScrollViewer>

            <Grid Grid.Column="1" Margin="10,0,0,0" MinHeight="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="True"
                                      Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Step 4: Run Patch" Style="{StaticResource SectionHeaderText}" VerticalAlignment="Center"/>
                                        <Border x:Name="bdStep4Status" Style="{StaticResource StepStatusChip}" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="txtStep4Status" Text="Pending" Style="{StaticResource StepStatusChipText}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Review the plan and start the patch when all steps are ready." Style="{StaticResource FieldLabelText}" Margin="0,6,0,0"/>
                                </StackPanel>

                                <Border x:Name="bdStatusBanner" Style="{StaticResource StatusBannerInfo}" Margin="0,0,0,10" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="txtNotification" Text="{Binding NotificationMessage}" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                        <ListBox x:Name="lstValidationIssues"
                                                 AutomationProperties.Name="Validation issues"
                                                 MaxHeight="88"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{DynamicResource Error}"
                                                 FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                    <StackPanel>
                                        <ProgressBar x:Name="progressBar"
                                                     Style="{StaticResource ModernProgressBar}"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding ProgressValue}"
                                                     Margin="0,0,0,8"/>

                                        <TextBlock x:Name="txtStatus" Text="{Binding StatusText}" Margin="0,0,0,6" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock x:Name="txtRunProgressDetail" Text="{Binding RunProgressDetailText}" Margin="0,0,0,6" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="txtResultSummary" Text="{Binding ResultSummary}" Margin="0,0,0,0" FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,5,5">
                                        <StackPanel>
                                            <TextBlock Text="Source Backup" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtRunSummarySource" Text="{Binding RunSummarySource}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="5,0,0,5">
                                        <StackPanel>
                                            <TextBlock Text="Upgrade Path" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtRunSummaryUpgradePath" Text="{Binding RunSummaryUpgradePath}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,5,5,0">
                                        <StackPanel>
                                            <TextBlock Text="SQL Target" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtRunSummaryConnection" Text="{Binding RunSummaryConnection}" Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="5,5,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Plan" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtRunSummaryPlan" Text="{Binding RunSummaryPlan}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,5,5,0">
                                        <StackPanel>
                                            <TextBlock Text="Output" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtRunSummaryOutput" Text="{Binding RunSummaryOutput}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="5,5,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Safeguards" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtRunSummarySafeguards" Text="{Binding RunSummarySafeguards}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Expander x:Name="expRunWarnings" IsExpanded="False">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Diagnostics" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                            <Border x:Name="bdWarningChip" Background="{DynamicResource WarningSoft}" BorderBrush="{DynamicResource Warning}" BorderThickness="1" CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                                <TextBlock x:Name="txtWarningChip" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Warning}"/>
                                            </Border>
                                        </StackPanel>
                                    </Expander.Header>

                                    <Border Background="{DynamicResource BgTertiary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,8,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <ListBox x:Name="lstRunWarnings"
                                                     MaxHeight="180"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="{DynamicResource TextPrimary}"
                                                     FontSize="12"
                                                     Margin="0,0,0,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource BgSecondary}"
                                                                BorderBrush="{DynamicResource BorderColor}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="10"
                                                                Margin="0,0,0,8">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TextPrimary}"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Subtitle}"
                                                                           Margin="0,4,0,0"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextMuted}"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Details}"
                                                                           Margin="0,6,0,0"
                                                                           FontSize="12"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <Border Grid.Row="1" Background="{DynamicResource BgSecondary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8">
                                                <Grid>
                                                    <ScrollViewer x:Name="logScrollViewer"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled">
                                                        <ItemsControl x:Name="lstLog"
                                                                      AutomationProperties.Name="Runtime log"
                                                                      ItemsSource="{Binding LogEntries}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Text}"
                                                                               FontFamily="Consolas"
                                                                               FontSize="12"
                                                                               TextWrapping="Wrap"
                                                                               Padding="0,1">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:LogSeverity.Warning}">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource Warning}"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:LogSeverity.Error}">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource Error}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                    <TextBlock x:Name="txtLogEmpty"
                                                               Text="Patch output will appear here when a run is started."
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"
                                                               IsHitTestVisible="False"
                                                               Visibility="Visible"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="btnRetryFromValidation" Content="Retry Validation" Style="{StaticResource BtnSecondary}" IsEnabled="False" Visibility="Collapsed" Margin="0,0,8,8" Click="BtnRetryFromValidation_Click"/>
                                <Button x:Name="btnCopyPatchPlan" TabIndex="6" Content="Copy Patch Plan" Style="{StaticResource BtnSecondary}" Margin="0,0,8,8" Click="BtnCopyPatchPlan_Click"/>
                                <Button x:Name="btnCopyDiagnostics" Content="Copy Diagnostics" AutomationProperties.Name="Copy diagnostics to clipboard" Style="{StaticResource BtnSecondary}" IsEnabled="False" Visibility="Collapsed" Margin="0,0,8,8" Click="BtnCopyDiagnostics_Click"/>
                                <Button x:Name="btnOpenOutputFolder" Content="Open Output Folder" AutomationProperties.Name="Open output folder" Style="{StaticResource BtnSecondary}" IsEnabled="False" Visibility="Collapsed" Margin="0,0,0,8" Click="BtnOpenOutputFolder_Click"/>
                            </WrapPanel>

                            <TextBlock x:Name="txtPatchActionHint"
                                       Text="{Binding PatchActionHint}"
                                       Grid.Row="1"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,8"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnCancel"
                                        TabIndex="7"
                                        Content="Cancel"
                                        AutomationProperties.Name="Cancel patch run"
                                        Style="{StaticResource BtnSecondary}"
                                        Margin="0,0,10,0"
                                        MinWidth="110"
                                        Padding="18,11"
                                        IsEnabled="False"
                                        Click="BtnCancel_Click"/>

                                <Button x:Name="btnPatch"
                                        TabIndex="8"
                                        Content="Start Patch"
                                        AutomationProperties.Name="Start patch run"
                                        Style="{StaticResource BtnPrimary}"
                                        IsDefault="True"
                                        MinWidth="180"
                                        Padding="28,12"
                                        Click="BtnPatch_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
