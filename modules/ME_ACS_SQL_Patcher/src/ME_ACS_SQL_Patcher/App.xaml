<Application x:Class="MagDbPatcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MagDbPatcher"
             xmlns:converters="clr-namespace:MagDbPatcher.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:NotificationLevelToBrushConverter x:Key="NotificationLevelToBrush"/>
            <converters:InverseBoolConverter x:Key="InverseBool"/>
            <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility"/>
            <converters:EnumToStringConverter x:Key="EnumToString"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
