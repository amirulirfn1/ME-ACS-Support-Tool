<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Brand -->
    <SolidColorBrush x:Key="BrandPrimary" Color="#1A1E2A"/>
    <SolidColorBrush x:Key="BrandPrimarySoft" Color="#1E2336"/>
    <SolidColorBrush x:Key="BrandAccent" Color="#4A87F5"/>
    <SolidColorBrush x:Key="BrandAccentSoft" Color="#1A2744"/>
    <SolidColorBrush x:Key="BrandAccentLine" Color="#3A6FD8"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="BgPrimary" Color="#0F1219"/>
    <SolidColorBrush x:Key="BgSecondary" Color="#1A1E2A"/>
    <SolidColorBrush x:Key="BgTertiary" Color="#1E2336"/>
    <SolidColorBrush x:Key="SurfaceRaised" Color="#222840"/>
    <SolidColorBrush x:Key="SurfaceSubtle" Color="#1E2336"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#252C42"/>
    <SolidColorBrush x:Key="SurfacePressed" Color="#2A3248"/>
    <SolidColorBrush x:Key="BorderColor" Color="#2E3A52"/>
    <SolidColorBrush x:Key="BorderStrong" Color="#3D4E6A"/>
    <SolidColorBrush x:Key="FocusRing" Color="#5B8DEF"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="Success" Color="#22B573"/>
    <SolidColorBrush x:Key="SuccessSoft" Color="#0B2418"/>
    <SolidColorBrush x:Key="Info" Color="#4A87F5"/>
    <SolidColorBrush x:Key="InfoSoft" Color="#0F1E3A"/>
    <SolidColorBrush x:Key="Warning" Color="#E8A838"/>
    <SolidColorBrush x:Key="WarningSoft" Color="#2A1E08"/>
    <SolidColorBrush x:Key="Error" Color="#EF5353"/>
    <SolidColorBrush x:Key="ErrorSoft" Color="#2A0F0F"/>
    <SolidColorBrush x:Key="SuccessFg" Color="#5FD9A8"/>
    <SolidColorBrush x:Key="ErrorFg" Color="#F08080"/>

    <!-- Typography -->
    <SolidColorBrush x:Key="TextPrimary" Color="#DDE3EF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#8A9DB8"/>
    <SolidColorBrush x:Key="TextMuted" Color="#576A85"/>
    <SolidColorBrush x:Key="TextInverse" Color="#0F1219"/>

    <!-- Compatibility aliases -->
    <SolidColorBrush x:Key="AccentGreen" Color="#22B573"/>
    <SolidColorBrush x:Key="AccentGreenHover" Color="#1A9460"/>
    <SolidColorBrush x:Key="AccentBlue" Color="#4A87F5"/>
    <SolidColorBrush x:Key="AccentRed" Color="#EF5353"/>

    <SolidColorBrush x:Key="SelectionBg" Color="#4A87F5"/>
    <SolidColorBrush x:Key="SelectionFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ProgressFillStart" Color="#4A87F5"/>
    <SolidColorBrush x:Key="ProgressFillEnd" Color="#22B573"/>
</ResourceDictionary>
