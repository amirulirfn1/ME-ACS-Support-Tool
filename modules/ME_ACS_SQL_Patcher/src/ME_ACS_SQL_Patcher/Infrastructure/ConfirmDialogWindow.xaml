<Window x:Class="MagDbPatcher.Infrastructure.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Width="860"
        Height="680"
        MinWidth="640"
        MinHeight="420"
        MaxWidth="1200"
        MaxHeight="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="txtTitle"
                           Text="Confirm action"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="txtHint"
                           Text="Review the details below before continuing."
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondary}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <TextBox x:Name="txtMessage"
                     Margin="16"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{StaticResource TextPrimary}"
                     FontFamily="Consolas"
                     FontSize="13"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     IsReadOnlyCaretVisible="False"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="txtFooter"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Use the scroll area to review the full patch plan."
                       FontSize="12"
                       Foreground="{StaticResource TextMuted}"/>

            <Button x:Name="btnSecondary"
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    MinWidth="120"
                    Padding="18,11"
                    Style="{StaticResource BtnSecondary}"
                    IsCancel="True"
                    Click="BtnSecondary_Click"/>

            <Button x:Name="btnPrimary"
                    Grid.Column="2"
                    MinWidth="140"
                    Padding="24,12"
                    Style="{StaticResource BtnPrimary}"
                    IsDefault="True"
                    Click="BtnPrimary_Click"/>
        </Grid>
    </Grid>
</Window>
